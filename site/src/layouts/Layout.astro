---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Sellers Family | Hoping to Adopt",
  description = "Meet Daniel, Katie, and their two kids. We're a family in Holladay, Utah hoping to grow through open adoption."
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="alternate" type="application/rss+xml" title="The Sellers Family Journal" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;600;700;800&family=Josefin+Sans:wght@300;400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-warm-50 text-warm-800 font-sans">
    <nav class="sticky top-0 z-50 bg-warm-50/95 backdrop-blur-sm border-b border-brass-500/40">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-display text-2xl font-bold tracking-widest text-warm-800 hover:text-sky-600 transition-colors uppercase">
          The Sellers
        </a>
        <div class="hidden md:flex gap-7 text-xs font-medium uppercase tracking-widest">
          <a href="/" class="text-warm-700 hover:text-sky-600 transition-colors">Home</a>
          <a href="/about" class="text-warm-700 hover:text-sky-600 transition-colors">About</a>
          <a href="/our-home" class="text-warm-700 hover:text-sky-600 transition-colors">Our Home</a>
          <a href="/letter" class="text-warm-700 hover:text-sky-600 transition-colors">Letter</a>
          <a href="/pictures" class="text-warm-700 hover:text-sky-600 transition-colors">Pictures</a>
          <a href="/blog" class="text-warm-700 hover:text-sky-600 transition-colors">Journal</a>
          <a href="/contact" class="text-warm-700 hover:text-sky-600 transition-colors">Contact</a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden p-2 text-warm-700" aria-label="Open menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-brass-500/40 bg-warm-50">
        <div class="px-6 py-4 flex flex-col gap-3 text-xs font-medium uppercase tracking-widest">
          <a href="/" class="text-warm-700 hover:text-sky-600 py-1">Home</a>
          <a href="/about" class="text-warm-700 hover:text-sky-600 py-1">About</a>
          <a href="/our-home" class="text-warm-700 hover:text-sky-600 py-1">Our Home</a>
          <a href="/letter" class="text-warm-700 hover:text-sky-600 py-1">Letter</a>
          <a href="/pictures" class="text-warm-700 hover:text-sky-600 py-1">Pictures</a>
          <a href="/blog" class="text-warm-700 hover:text-sky-600 py-1">Journal</a>
          <a href="/contact" class="text-warm-700 hover:text-sky-600 py-1">Contact</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="bg-warm-800 text-warm-50 mt-24">
      <div class="max-w-6xl mx-auto px-6 py-12 grid md:grid-cols-3 gap-8 items-start">
        <div>
          <p class="font-display text-2xl font-bold tracking-widest uppercase">
            The Sellers
          </p>
          <p class="text-sm text-warm-100 mt-2 font-light">Holladay, Utah</p>
        </div>
        <div class="text-sm font-light text-warm-100 leading-relaxed md:col-span-2 md:text-right">
          <p>A family of four hoping to grow through open adoption.</p>
          <p class="mt-3 flex flex-wrap gap-x-6 gap-y-2 md:justify-end">
            <a href="/contact" class="text-brass-300 hover:text-sky-300 underline underline-offset-4 decoration-brass-500/50">
              Get in touch &rarr;
            </a>
            <a href="/rss.xml" class="text-brass-300 hover:text-sky-300 underline underline-offset-4 decoration-brass-500/50">
              Subscribe via RSS
            </a>
          </p>
        </div>
      </div>
      <div class="border-t border-brass-500/30">
        <div class="max-w-6xl mx-auto px-6 py-4 text-xs uppercase tracking-widest text-warm-200/70 font-light">
          &copy; {new Date().getFullYear()} The Sellers Family
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
