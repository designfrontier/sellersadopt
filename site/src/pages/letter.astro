---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const entry = await getEntry('pages', 'letter');
if (!entry) {
  throw new Error('Missing required content entry: pages/letter');
}
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} | The Sellers Family`}
  description={entry.data.summary ?? 'A personal letter from Daniel and Katie Sellers to expectant parents considering adoption.'}
>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="font-serif text-3xl md:text-4xl text-warm-800 mb-8 text-center">
      {entry.data.title}
    </h1>

    <div class="bg-white rounded-2xl shadow-sm p-8 md:p-12 font-serif text-warm-800 leading-relaxed prose prose-warm max-w-none">
      <Content />
    </div>

    <div class="text-center mt-8">
      <a
        href="/contact"
        class="inline-block px-6 py-3 bg-sage-600 text-white rounded-lg font-medium hover:bg-sage-700 transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
