---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const entry = await getEntry('pages', 'letter');
if (!entry) {
  throw new Error('Missing required content entry: pages/letter');
}
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} | The Sellers Family`}
  description={entry.data.summary ?? 'A personal letter from Daniel and Katie Sellers to expectant parents considering adoption.'}
>
  <header class="border-b border-brass-500/30">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <p class="font-heading text-xs uppercase tracking-[0.3em] text-brass-600 mb-4">
        A Letter
      </p>
      <h1 class="font-display text-5xl md:text-6xl font-bold uppercase leading-[0.95] text-warm-800 tracking-tight">
        {entry.data.title}
      </h1>
      {entry.data.summary && (
        <p class="mt-6 text-lg text-warm-700 leading-relaxed font-light max-w-2xl">
          {entry.data.summary}
        </p>
      )}
    </div>
  </header>

  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="max-w-3xl border-t-4 border-sage-600 pt-10">
      <div class="prose prose-warm max-w-none text-warm-800 leading-relaxed text-lg font-light">
        <Content />
      </div>

      <div class="mt-12 pt-10 border-t border-brass-500/30">
        <a
          href="/contact"
          class="inline-block px-7 py-3 bg-sage-600 text-warm-50 font-heading font-medium uppercase tracking-widest text-sm border border-sage-600 hover:bg-sage-700 hover:border-sage-700 transition-colors"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </section>
</Layout>
