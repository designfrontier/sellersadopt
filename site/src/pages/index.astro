---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

// Family-at-a-glance cards: pulled from the `family` collection,
// sorted by `order`. Hero/intro/openness copy stays inline (decision:
// homepage marketing copy is short and tightly tied to layout, so
// moving it into `pages` entries was deemed not worth the extra
// indirection for a 1-page site).
const family = (await getCollection('family')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout>
  <!-- Hero -->
  <section class="relative bg-sage-50">
    <div class="max-w-5xl mx-auto px-4 py-16 md:py-24 text-center">
      <!-- Replace with your family photo -->
      <div class="w-full max-w-2xl mx-auto aspect-[3/2] bg-warm-200 rounded-2xl mb-8 flex items-center justify-center text-warm-400">
        <p class="text-sm">Your family photo here</p>
      </div>
      <h1 class="font-serif text-4xl md:text-5xl text-warm-800 mb-4">
        We're the Sellers
      </h1>
      <p class="text-lg md:text-xl text-warm-600 max-w-2xl mx-auto leading-relaxed">
        A family of four in Holladay, Utah, hoping to welcome one more
        through open adoption.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/letter" class="inline-block px-6 py-3 bg-sage-600 text-white rounded-lg font-medium hover:bg-sage-700 transition-colors">
          Read Our Letter
        </a>
        <a href="/contact" class="inline-block px-6 py-3 bg-warm-200 text-warm-800 rounded-lg font-medium hover:bg-warm-300 transition-colors">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <!-- Quick intro -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-serif text-2xl md:text-3xl text-warm-800 mb-4">
          A little about us
        </h2>
        <p class="text-warm-700 leading-relaxed mb-4">
          We're Daniel and Katie. We live in Holladay, Utah with our two
          kids — E (10) and C (6). Our house is loud, full of laughter,
          and there's always room at the table.
        </p>
        <p class="text-warm-700 leading-relaxed">
          We believe in open adoption and are excited to build a
          relationship with a birth family. We know this is a deeply
          personal decision, and we respect your journey completely.
        </p>
        <a href="/about" class="inline-block mt-4 text-sage-600 font-medium hover:text-sage-700 transition-colors">
          Learn more about us &rarr;
        </a>
      </div>
      <div class="aspect-square bg-warm-200 rounded-2xl flex items-center justify-center text-warm-400">
        <p class="text-sm">Family photo</p>
      </div>
    </div>
  </section>

  <!-- Family at a glance — driven by the `family` content collection -->
  <section class="bg-warm-100 py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-serif text-2xl md:text-3xl text-warm-800 mb-8 text-center">
        Our family at a glance
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {family.map((member) => (
          <div class="bg-white rounded-xl p-6 text-center">
            {member.data.photo ? (
              <Image
                src={member.data.photo}
                alt={`Photo of ${member.data.name}`}
                class="w-20 h-20 rounded-full mx-auto mb-3 object-cover"
              />
            ) : (
              <div class="w-20 h-20 rounded-full bg-sage-100 mx-auto mb-3 flex items-center justify-center text-sage-400 text-xs">
                Photo
              </div>
            )}
            <h3 class="font-serif text-lg text-warm-800">{member.data.name}</h3>
            <p class="text-sm text-warm-600 mt-1">{member.data.traits}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open adoption commitment -->
  <section class="max-w-3xl mx-auto px-4 py-16 text-center">
    <h2 class="font-serif text-2xl md:text-3xl text-warm-800 mb-4">
      Our promise of openness
    </h2>
    <p class="text-warm-700 leading-relaxed mb-6">
      We believe open adoption is best for everyone — especially the child.
      We're committed to building a genuine, lasting relationship with you.
      That means regular updates, photos, video calls, and visits as we
      navigate this together.
    </p>
    <a href="/letter" class="inline-block px-6 py-3 bg-sage-600 text-white rounded-lg font-medium hover:bg-sage-700 transition-colors">
      Read Our Full Letter
    </a>
  </section>

  <!-- Contact CTA — info directly on homepage (real contact details, kept static) -->
  <section class="bg-sage-50 py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-serif text-2xl md:text-3xl text-warm-800 mb-4">
        We'd love to hear from you
      </h2>
      <p class="text-warm-700 leading-relaxed mb-6">
        Whether you have questions, want to learn more about our family,
        or just want to say hello — we're here. No pressure, no judgment.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center text-warm-700">
        <a href="tel:+18019300358" class="hover:text-sage-600 transition-colors">
          (801) 930-0358
        </a>
        <span class="hidden sm:inline text-warm-300">|</span>
        <a href="mailto:hello@sellersadopt.com" class="hover:text-sage-600 transition-colors">
          hello@sellersadopt.com
        </a>
        <span class="hidden sm:inline text-warm-300">|</span>
        <a href="https://instagram.com/sellersadopt" class="hover:text-sage-600 transition-colors" target="_blank" rel="noopener">
          @sellersadopt
        </a>
      </div>
    </div>
  </section>
</Layout>
