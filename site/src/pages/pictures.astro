---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

const gallery = (await getCollection('gallery')).sort((a, b) => {
  const aT = a.data.takenAt?.getTime() ?? 0;
  const bT = b.data.takenAt?.getTime() ?? 0;
  return bT - aT;
});
---

<Layout
  title="Pictures | The Sellers Family"
  description="A peek into our life — the Sellers family in Holladay, Utah."
>
  <section class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="font-serif text-3xl md:text-4xl text-warm-800 mb-4 text-center">
      A peek into our life
    </h1>
    <p class="text-warm-600 text-center max-w-2xl mx-auto mb-12">
      Just some of our favorite moments.
    </p>

    {gallery.length === 0 ? (
      <div class="text-center py-16">
        <p class="text-warm-600 text-lg">
          Photos coming soon — we're putting these together.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {gallery.map((item) => (
          <figure>
            <Image
              src={item.data.image}
              alt={item.data.alt}
              class="aspect-square w-full h-auto object-cover rounded-xl"
            />
            {(item.data.caption || item.data.season) && (
              <figcaption class="text-warm-600 text-xs mt-2 flex items-center gap-2">
                {item.data.caption && <span>{item.data.caption}</span>}
                {item.data.season && (
                  <span class="inline-block px-2 py-0.5 rounded-full bg-warm-100 text-warm-500 text-[10px] uppercase tracking-wide">
                    {item.data.season}
                  </span>
                )}
              </figcaption>
            )}
          </figure>
        ))}
      </div>
    )}
  </section>
</Layout>
