---
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

const entry = await getEntry('pages', 'our-home');
if (!entry) {
  throw new Error('Missing required content entry: pages/our-home');
}
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} | The Sellers Family`}
  description={entry.data.summary ?? 'See where we live in Holladay, Utah — our home, neighborhood, and community.'}
>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="font-serif text-3xl md:text-4xl text-warm-800 mb-8 text-center">
      {entry.data.title}
    </h1>

    {entry.data.hero && (
      <div class="mb-10">
        <Image
          src={entry.data.hero}
          alt={entry.data.title}
          class="w-full h-auto rounded-2xl"
        />
      </div>
    )}

    <div class="prose prose-warm max-w-none text-warm-700 leading-relaxed">
      <Content />
    </div>
  </section>
</Layout>
