---
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

const entry = await getEntry('pages', 'our-home');
if (!entry) {
  throw new Error('Missing required content entry: pages/our-home');
}
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} | The Sellers Family`}
  description={entry.data.summary ?? 'See where we live in Holladay, Utah: our home, neighborhood, and community.'}
>
  <header class="border-b border-brass-500/30">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <p class="font-heading text-xs uppercase tracking-[0.3em] text-brass-600 mb-4">
        Where We Live
      </p>
      <h1 class="font-display text-5xl md:text-6xl font-bold uppercase leading-[0.95] text-warm-800 tracking-tight">
        {entry.data.title}
      </h1>
      {entry.data.summary && (
        <p class="mt-6 text-lg text-warm-700 leading-relaxed font-light max-w-2xl">
          {entry.data.summary}
        </p>
      )}
    </div>
  </header>

  {entry.data.hero && (
    <div class="max-w-5xl mx-auto px-6 pt-12">
      <div class="border-4 border-brass-500 overflow-hidden">
        <Image
          src={entry.data.hero}
          alt={entry.data.title}
          class="w-full h-auto block"
        />
      </div>
    </div>
  )}

  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="prose prose-warm max-w-3xl text-warm-800 leading-relaxed text-lg font-light">
      <Content />
    </div>
  </section>
</Layout>
