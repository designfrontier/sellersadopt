---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<Layout
  title={`${post.data.title} | The Sellers Family`}
  description={post.data.summary ?? 'A post from the Sellers family adoption journey.'}
>
  <header class="border-b border-brass-500/30">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <a
        href="/blog"
        class="inline-block font-heading text-xs uppercase tracking-[0.3em] text-brass-600 hover:text-sky-600 transition-colors mb-6"
      >
        &larr; All Posts
      </a>
      <time class="block font-heading text-xs uppercase tracking-[0.3em] text-brass-600 mb-4" datetime={post.data.date.toISOString()}>
        {dateFmt.format(post.data.date)}
      </time>
      <h1 class="font-display text-5xl md:text-6xl font-bold uppercase leading-[0.95] text-warm-800 tracking-tight">
        {post.data.title}
      </h1>
      {post.data.summary && (
        <p class="mt-6 text-lg text-warm-700 leading-relaxed font-light max-w-2xl">
          {post.data.summary}
        </p>
      )}
    </div>
  </header>

  {post.data.hero && (
    <div class="max-w-5xl mx-auto px-6 pt-12">
      <div class="border-4 border-brass-500 overflow-hidden aspect-[3/2]">
        <Image
          src={post.data.hero}
          alt={post.data.title}
          class="w-full h-full object-cover block"
        />
      </div>
    </div>
  )}

  <article class="max-w-5xl mx-auto px-6 py-16">
    <div class="prose prose-warm max-w-3xl text-warm-800 leading-relaxed text-lg font-light">
      <Content />
    </div>
  </article>
</Layout>
