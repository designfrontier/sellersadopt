---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const entry = await getEntry('pages', 'about');
if (!entry) {
  throw new Error('Missing required content entry: pages/about');
}
const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} | The Sellers Family`}
  description={entry.data.summary ?? 'Learn about Daniel and Katie Sellers and why we’re choosing open adoption.'}
>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="font-serif text-3xl md:text-4xl text-warm-800 mb-8 text-center">
      {entry.data.title}
    </h1>

    <div class="prose prose-warm max-w-none text-warm-700 leading-relaxed">
      <Content />
    </div>
  </section>
</Layout>
