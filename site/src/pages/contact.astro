---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | The Sellers Family" description="Get in touch with Daniel and Katie Sellers. We'd love to hear from you.">
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="font-serif text-3xl md:text-4xl text-warm-800 mb-4 text-center">
      Get in Touch
    </h1>
    <p class="text-warm-600 text-center max-w-xl mx-auto mb-12">
      We'd love to hear from you — whether you have questions, want to
      learn more, or just want to connect. No pressure, no judgment.
      Reach out however feels most comfortable.
    </p>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Direct contact -->
      <div>
        <h2 class="font-serif text-xl text-warm-800 mb-6">Reach us directly</h2>

        <div class="space-y-6">
          <div>
            <h3 class="font-medium text-warm-800 mb-1">Email</h3>
            <a href="mailto:hello@sellersadopt.com" class="text-sage-600 hover:text-sage-700">
              hello@sellersadopt.com
            </a>
          </div>

          <div>
            <h3 class="font-medium text-warm-800 mb-1">Phone / Text</h3>
            <a href="tel:+18019300358" class="text-sage-600 hover:text-sage-700">
              (801) 930-0358
            </a>
            <p class="text-warm-500 text-sm mt-1">Call or text — whatever is easier for you.</p>
          </div>

          <div>
            <h3 class="font-medium text-warm-800 mb-1">Social</h3>
            <!-- TODO: Update href once Instagram account is created -->
            <a href="https://instagram.com/sellersadopt" class="text-sage-600 hover:text-sage-700" target="_blank" rel="noopener">
              @sellersadopt on Instagram
            </a>
          </div>
        </div>
      </div>

      <!-- Right column -->
      <div>
        <h2 class="font-serif text-xl text-warm-800 mb-6">What to expect</h2>
        <ul class="space-y-3 text-warm-700 text-sm">
          <li class="flex gap-2">
            <span class="text-sage-500 mt-0.5">&#10003;</span>
            <span>We respond within 24 hours</span>
          </li>
          <li class="flex gap-2">
            <span class="text-sage-500 mt-0.5">&#10003;</span>
            <span>Everything is completely confidential</span>
          </li>
          <li class="flex gap-2">
            <span class="text-sage-500 mt-0.5">&#10003;</span>
            <span>No pressure — just a conversation</span>
          </li>
          <li class="flex gap-2">
            <span class="text-sage-500 mt-0.5">&#10003;</span>
            <span>We're happy to answer any questions</span>
          </li>
        </ul>

        <div class="mt-8 bg-warm-100 rounded-xl p-6">
          <p class="font-medium text-warm-800 mb-2">The best way to reach us is directly</p>
          <p class="text-warm-600 text-sm leading-relaxed">
            Email, call, or text — whichever feels right. We're real
            people, not an agency, and we'd love to hear from you
            personally.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
