---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | The Sellers Family" description="Get in touch with Daniel and Katie Sellers. We'd love to hear from you.">
  <header class="border-b border-brass-500/30">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <p class="font-heading text-xs uppercase tracking-[0.3em] text-brass-600 mb-4">
        Hello
      </p>
      <h1 class="font-display text-5xl md:text-6xl font-bold uppercase leading-[0.95] text-warm-800 tracking-tight">
        Get in <span class="relative inline-block pb-1">Touch<span class="absolute left-0 bottom-0 h-[6px] w-full bg-sky-500"></span></span>
      </h1>
      <p class="mt-6 text-lg text-warm-700 leading-relaxed font-light max-w-2xl">
        We'd love to hear from you, whether you have questions, want to
        learn more, or just want to connect. No pressure, no judgment.
      </p>
    </div>
  </header>

  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-2 gap-14">
      <div>
        <p class="font-heading text-xs uppercase tracking-[0.3em] text-brass-600 mb-6">
          Reach Us Directly
        </p>

        <div class="space-y-8">
          <div>
            <h3 class="font-heading text-xs uppercase tracking-widest text-warm-700 mb-2">Email</h3>
            <a href="mailto:hello@sellersadopt.com" class="font-display text-2xl uppercase tracking-tight text-warm-800 hover:text-sky-600 transition-colors">
              hello@sellersadopt.com
            </a>
          </div>

          <div>
            <h3 class="font-heading text-xs uppercase tracking-widest text-warm-700 mb-2">Phone &middot; Text</h3>
            <a href="tel:+18019300358" class="font-display text-2xl uppercase tracking-tight text-warm-800 hover:text-sky-600 transition-colors">
              (801) 930-0358
            </a>
            <p class="text-warm-600 text-sm mt-2 font-light">Call or text. Whatever is easier for you.</p>
          </div>

          <div>
            <h3 class="font-heading text-xs uppercase tracking-widest text-warm-700 mb-2">Social</h3>
            <a href="https://instagram.com/sellersadopt" class="font-display text-2xl uppercase tracking-tight text-warm-800 hover:text-sky-600 transition-colors" target="_blank" rel="noopener">
              @sellersadopt
            </a>
            <p class="text-warm-600 text-sm mt-2 font-light">on Instagram</p>
          </div>
        </div>
      </div>

      <div>
        <p class="font-heading text-xs uppercase tracking-[0.3em] text-brass-600 mb-6">
          What to Expect
        </p>
        <ul class="space-y-4 text-warm-800 font-light text-lg">
          <li class="flex gap-3">
            <span class="text-sky-500 font-heading mt-1.5 text-sm">&#10003;</span>
            <span>We respond within 24 hours</span>
          </li>
          <li class="flex gap-3">
            <span class="text-sky-500 font-heading mt-1.5 text-sm">&#10003;</span>
            <span>Everything is completely confidential</span>
          </li>
          <li class="flex gap-3">
            <span class="text-sky-500 font-heading mt-1.5 text-sm">&#10003;</span>
            <span>No pressure, just a conversation</span>
          </li>
          <li class="flex gap-3">
            <span class="text-sky-500 font-heading mt-1.5 text-sm">&#10003;</span>
            <span>We're happy to answer any questions</span>
          </li>
        </ul>

        <div class="mt-10 bg-warm-800 text-warm-50 relative">
          <div class="h-2 bg-sky-500" aria-hidden="true"></div>
          <div class="p-7 md:p-8">
            <p class="font-display text-2xl md:text-3xl uppercase font-bold tracking-tight leading-[0.95] mb-3">
              Real people,<br/>not an agency
            </p>
            <p class="text-warm-100 font-light leading-relaxed">
              Email, call, or text. Whichever feels right. We're real
              people, and we'd love to hear from you personally.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
