---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog | The Sellers Family" description="Updates from the Sellers family on our adoption journey.">
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="font-serif text-3xl md:text-4xl text-warm-800 mb-4 text-center">
      Our Journey
    </h1>
    <p class="text-warm-600 text-center max-w-xl mx-auto mb-12">
      Updates, reflections, and moments from our family as we
      grow through adoption.
    </p>

    <!-- Blog posts — newest first -->
    <div class="space-y-12">

      <!-- First post template -->
      <article class="border-b border-warm-200 pb-12">
        <time class="text-warm-400 text-sm">March 2026</time>
        <h2 class="font-serif text-2xl text-warm-800 mt-2 mb-4">
          Why we're choosing adoption
        </h2>
        <p class="text-warm-700 leading-relaxed mb-3">
          <!-- TODO: Write your first blog post. This is a great place to share
               your "why" in a more personal, longer-form way than the letter.
               Think of it as a journal entry, not an essay. -->
          [Your first post — to be filled in]
        </p>
      </article>

      <!-- Future posts go here, newest on top -->
      <!--
      <article class="border-b border-warm-200 pb-12">
        <time class="text-warm-400 text-sm">Month Year</time>
        <h2 class="font-serif text-2xl text-warm-800 mt-2 mb-4">
          Post title
        </h2>
        <p class="text-warm-700 leading-relaxed mb-3">
          Post content
        </p>
      </article>
      -->

    </div>
  </section>
</Layout>
