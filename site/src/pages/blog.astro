---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<Layout
  title="Blog | The Sellers Family"
  description="Updates from the Sellers family on our adoption journey."
>
  <header class="border-b border-brass-500/30">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <p class="font-heading text-xs uppercase tracking-[0.3em] text-brass-600 mb-4">
        Journal
      </p>
      <h1 class="font-display text-5xl md:text-6xl font-bold uppercase leading-[0.95] text-warm-800 tracking-tight">
        Our <span class="relative inline-block pb-1">Journey<span class="absolute left-0 bottom-0 h-[6px] w-full bg-sky-500"></span></span>
      </h1>
      <p class="mt-6 text-lg text-warm-700 leading-relaxed font-light max-w-2xl">
        Updates, reflections, and moments from our family as we grow through adoption.
      </p>
    </div>
  </header>

  <section class="max-w-5xl mx-auto px-6 py-16">
    {posts.length === 0 ? (
      <p class="text-warm-700 font-light">No posts yet. Check back soon.</p>
    ) : (
      <div class="space-y-14 max-w-3xl">
        {posts.map((post) => (
          <article class="border-b border-brass-500/30 pb-14 last:border-b-0">
            <time class="font-heading text-xs uppercase tracking-[0.3em] text-brass-600" datetime={post.data.date.toISOString()}>
              {dateFmt.format(post.data.date)}
            </time>
            <h2 class="font-display text-3xl md:text-4xl uppercase font-bold leading-[0.95] text-warm-800 mt-3 mb-4 tracking-tight">
              <a
                href={`/blog/${post.id}`}
                class="hover:text-sky-600 transition-colors"
              >
                {post.data.title}
              </a>
            </h2>
            {post.data.summary && (
              <p class="text-warm-800 leading-relaxed font-light text-lg">
                {post.data.summary}
              </p>
            )}
            <a
              href={`/blog/${post.id}`}
              class="inline-block mt-4 font-heading text-sm uppercase tracking-widest text-sky-600 hover:text-sky-700 border-b border-sky-500/40 pb-1"
            >
              Read more &rarr;
            </a>
          </article>
        ))}
      </div>
    )}
  </section>
</Layout>
